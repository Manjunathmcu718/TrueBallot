MONGO_URI=mongodb://localhost:27017/voter_auth_db

# Twilio SMS setup
# Use your Account SID and Auth Token from the Twilio Console.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# This must be an SMS-capable Twilio phone number, not your personal verified number.
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
